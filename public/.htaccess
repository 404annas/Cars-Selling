DirectoryIndex index.html

<IfModule mod_rewrite.c>
  RewriteEngine On

  # Next static export creates route folders such as /dashboard/login/index.html.
  # Hostinger sometimes does not resolve the same route without the trailing slash.
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteCond %{REQUEST_URI} !/$
  RewriteRule ^(.+)$ %{REQUEST_URI}/ [R=301,L]

  # Serve exported route folders when a clean URL is requested.
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{DOCUMENT_ROOT}/$1/index.html -f
  RewriteRule ^(.+?)/?$ /$1/index.html [L]

  # Let static files and Next assets pass through normally.
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  ErrorDocument 404 /404.html
</IfModule>
